{
  "name": "@darksol/terminal",
  "version": "0.19.0",
  "description": "DARKSOL Terminal — unified crypto CLI for trading, Wiretap/AIM messaging, agent tooling, x402 payments, market intel, wallets, oracle, cards, and more.",
  "type": "module",
  "bin": {
    "darksol": "bin/darksol.js"
  },
  "main": "./src/cli.js",
  "files": [
    "assets/",
    "bin/",
    "skill/",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/darksol.js",
    "dev": "node bin/darksol.js dashboard",
    "test": "node --test tests/*.test.js",
    "postinstall": "echo \"\n🌑 DARKSOL Terminal installed. Run 'darksol setup' to configure your AI provider.\n\""
  },
  "keywords": [
