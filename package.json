    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "ethers": "^6.13.0",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "inquirer": "^12.0.0",
    "nanospinner": "^1.1.0",
    "node-fetch": "^3.3.2",
    "open": "^11.0.0",
    "ora": "^8.1.0",
